{
  "name": "resysnipe",
  "version": "1.0.0",
  "description": "Reservation monitoring tool that polls Resy for availability and sends email alerts",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "snipe": "node snipe.js",
    "test-resy": "node test-resy.js",
    "build:dashboard": "esbuild dashboard/App.jsx --bundle --outfile=public/app.js --loader:.jsx=jsx",
    "dashboard": "npm run build:dashboard && node server/index.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
